{
    "apps": [
        {
            "name": "blog-fe",
            "script": "server.js",
            "env": {
                "NODE_ENV": "production",
                "PORT": "3000"
            },
            "instances": 1,
            "exec_mode": "cluster",
            "max_memory_restart": "1G",
            "error_file": "/tmp/app-err.log",
            "out_file": "/tmp/app-out.log",
            "log_file": "/tmp/app-combined.log",
            "time": true
        }
    ]
} 