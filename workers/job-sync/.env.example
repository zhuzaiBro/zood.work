# Postgres / Supabase Database
# 建议使用 Supabase Transaction Pooler 或 Direct Connection 的连接串
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# DeJob API
DEJOB_USER_TOKEN=your_dejob_x_user_token

# Worker mode
# RUN_ONCE=true  -> 执行一次后退出（适合 cron / Docker 定时任务）
# RUN_ONCE=false -> 启动 HTTP 服务，POST /sync 触发同步
RUN_ONCE=true
HTTP_ADDR=:8080
CRON_SECRET=your_random_cron_secret

# 岗位来源：默认同步全部 active sources；也可以指定多个：dejob,cake
# 同步 Cake.me 前先执行 .sql/setup_cake_job_source.sql
JOB_SOURCE_SLUG=all
# JOB_SOURCE_SLUGS=dejob,cake

# 对外展示链接
SITE_BASE_URL=https://zood.work

# 岗位检索
# 可选：只响应指定前缀后的关键词，例如 "岗位"
JOB_SEARCH_PREFIX=

# Telegram Bot（RUN_ONCE=false HTTP 模式启用）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret
# 本地/内网推荐 true：worker 会通过 getUpdates 托管 bot，不依赖公网 webhook
TELEGRAM_POLLING_ENABLED=false
# polling 模式下建议 true，避免 Telegram webhook 与 getUpdates 冲突
TELEGRAM_DELETE_WEBHOOK_ON_POLLING=true

# Discord Bot Interaction Endpoint（RUN_ONCE=false HTTP 模式启用）
DISCORD_PUBLIC_KEY=your_discord_application_public_key
DISCORD_COMMAND_NAME=jobs

# MCP / Agent HTTP 鉴权，可为空；生产建议填写
MCP_AUTH_TOKEN=your_mcp_bearer_token
AGENT_AUTH_TOKEN=your_agent_bearer_token
